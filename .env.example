# ─── API Keys ───
# .env should only contain secrets and sensitive values.
# Evaluation settings belong in eval.yaml.
# Do not commit real keys. Any fixture / task credentials in this repo are
# fictional test values and must not be reused in real environments.

# Option 1: direct Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# Option 2: relay / proxy provider (recommended)
# Keep only the API key here; put base_url / api_format / headers under
# providers: in eval.yaml.
# Use a descriptive <NAME> such as RELAY / OPENROUTER / DEEPSEEK.
# EVAL_PROVIDER_<NAME>_API_KEY=
#
# Example:
# EVAL_PROVIDER_MYRELAY_API_KEY=sk-xxx
